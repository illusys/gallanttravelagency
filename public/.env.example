# Google Analytics 4 Measurement ID.
# Current production tag provided by Gallant Travel Agency: G-8MZD5NT84G.
# The app falls back to this value if NEXT_PUBLIC_GA_ID is not set.
NEXT_PUBLIC_GA_ID=G-8MZD5NT84G

# Meta/Facebook Pixel ID.
# Current production Pixel ID provided by Gallant Travel Agency: 27257858243820733.
# The app falls back to this value if NEXT_PUBLIC_META_PIXEL_ID is not set.
NEXT_PUBLIC_META_PIXEL_ID=27257858243820733

# Resend API key used by the contact form API route to send lead notifications.
RESEND_API_KEY=

# Optional verified sender for Resend. Defaults to Resend onboarding sender if omitted.
# For production, configure a verified domain in Resend and set this value.
RESEND_FROM_EMAIL="Gallant Travel Agency <hello@gallanttravel.ng>"

# Contact notification recipients.
CONTACT_RECEIVING_EMAIL_1=gallanttravels@yahoo.com
CONTACT_RECEIVING_EMAIL_2=hello@gallanttravel.ng

# Google Apps Script Web App URL that appends contact submissions to Google Sheets.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbxfXT7m5voSEYFv9mKe95ZAZolFJVWFBSYRypcYeQzad74TdGMILIa9ML7B8ErOvc1s/exec
